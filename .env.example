# Configuração local do repositório (não versionar `.env`).
# Copie:  copy .env.example .env
#
# IMPORTANTE: não coloque credenciais aqui (tokens, senhas, JWT).
# Credenciais ficam nas variáveis de ambiente do utilizador/sistema:
#
#   Windows (PowerShell, persistente):
#     [Environment]::SetEnvironmentVariable("RASTREAME_AUTH", "<token>", "User")
#     [Environment]::SetEnvironmentVariable("RASTREAME_LOGIN", "<email>", "User")
#     [Environment]::SetEnvironmentVariable("RASTREAME_SENHA", "<senha>", "User")
#     [Environment]::SetEnvironmentVariable("DETRAN_SC_AUTH", "<jwt>", "User")
#     [Environment]::SetEnvironmentVariable("DETRAN_SC_EMPRESA", "<empresa>", "User")
#     [Environment]::SetEnvironmentVariable("DETRAN_RS_AUTH", "<bearer>", "User")
#     [Environment]::SetEnvironmentVariable("DETRAN_RS_USER_ID", "<base64 do CPF>", "User")
#     # Login gov.br por CERTIFICADO A1 (recomendado; .\scripts\login-detran-rs.ps1 -Pfx ... -PfxPass ...):
#     [Environment]::SetEnvironmentVariable("DETRAN_RS_PFX_PATH", "C:\caminho\cert.pfx", "User")
#     [Environment]::SetEnvironmentVariable("DETRAN_RS_PFX_PASS", "<senha-pfx>", "User")
#     # Fallback CPF/senha (você resolve o reCAPTCHA):
#     [Environment]::SetEnvironmentVariable("DETRAN_RS_GOV_CPF", "<cpf>", "User")
#     [Environment]::SetEnvironmentVariable("DETRAN_RS_GOV_SENHA", "<senha>", "User")
#     [Environment]::SetEnvironmentVariable("PEDAGIO_DIGITAL_LOGIN", "<cpf>", "User")
#     [Environment]::SetEnvironmentVariable("PEDAGIO_DIGITAL_SENHA", "<senha>", "User")
#
#   Ou: .\scripts\set-rastreame-auth-user-env.ps1 -Token "<token>"
#
# Feche e reabra o terminal (ou o Cursor) após definir variáveis de utilizador.

# Apenas se o Node falhar com UNABLE_TO_VERIFY_LEAF_SIGNATURE ao chamar rastreame.com.br:
# RASTREAME_TLS_INSECURE=1
# (mesma necessidade para DETRAN SC/RS nesta rede:)
# DETRAN_SC_TLS_INSECURE=1
# DETRAN_RS_TLS_INSECURE=1

# Opcional — versão do app DETRAN (não é credencial):
# DETRAN_SC_APP_VERSION=2026-06-26-1612

# LANZA_JWT_SECRET=<string-aleatoria-longa>   # obrigatório para login/registo no painel web
# LANZA_JWT_EXPIRES_IN=7d                     # opcional (default 7 dias)
# LANZA_ALLOW_REGISTER=true                     # permite registo público após o 1.º utilizador
# LANZA_API_KEY=                                # opcional — chave partilhada para scripts/CLI

# PostgreSQL / RDS AWS (host e role não são segredo; senha via PGPASSWORD localmente):
#   .\scripts\set-postgres-user-env.ps1 -PromptPassword   # recomendado para sync local
#   npm run lanza -- postgres check
#   npm run lanza -- postgres sync-all
# PGHOST=aws-pg-lanza-locacoes.cluster-....us-east-1.rds.amazonaws.com
# PGPORT=5432
# PGDATABASE=postgres
# PGUSER=postgres
# PGSSLMODE=require
# AWS_REGION=us-east-1
# AWS_ROLE_ARN=arn:aws:iam::154601375525:role/Vercel/access-pg-lanza-locacoes  # só Vercel (OIDC)
# PGPASSWORD=   # senha RDS — obrigatória para CLI local (sync-store, migrate, etc.)
# DATABASE_URL=postgresql://user@host:5432/postgres?sslmode=require

# Vercel Blob — relatórios e documentos na nuvem (produção):
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# LANZA_STORAGE_PREFIX=lanza-docs
# LANZA_RASTREAME_ESPELHO=true   # replica cadastros/despesas/contratos no Rastreame (espelho)
# LANZA_RASTREAME_ESPELHO=false  # só Lanza/Postgres — Rastreame desligado (default na Vercel)
# LANZA_STORAGE_LOCAL_MIRROR=true   # dev sem token Blob: espelha em relatorios/_tmp/blob-mirror

# PostgreSQL relacional (substitui lanza.json_stores):
# LANZA_DB_BACKEND=postgres
# LANZA_DB_RELATIONAL=1              # default — tabelas normalizadas; 0 = legado json_stores
# LANZA_DB_READ_LEGACY=1             # rollback temporário: lê JSON/json_stores
# LANZA_DATABASE_DIR=D:\Dropbox\Aworklanza\lanza-locacoes-ai\database
# LANZA_JSON_BACKUP=0                # desliga export database/*.json após gravação SQL
