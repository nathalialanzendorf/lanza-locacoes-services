# Copie para `.env` na raiz do repositório (nunca versionar `.env`).
# Para copiar o valor para variáveis de ambiente persistentes do Windows (utilizador):
#   .\scripts\sync-rastreame-auth-user-env.ps1
RASTREAME_AUTH=

# DETRAN SC — servicos.detran.sc.gov.br (DevTools → Network → Authorization + X-Empresa)
# DETRAN_SC_AUTH=
# DETRAN_SC_EMPRESA=
# DETRAN_SC_APP_VERSION=2026-06-26-1612

# Apenas se o Node falhar com UNABLE_TO_VERIFY_LEAF_SIGNATURE ao chamar rastreame.com.br:
# RASTREAME_TLS_INSECURE=1

# RASTREAME_LOGIN=
# RASTREAME_SENHA=
