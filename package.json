  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "playwright-core": "^1.61.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.10",
    "pdf-parse": "^1.1.1",
    "pizzip": "^3.1.7"
  }
}
