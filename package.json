{
  "name": "lanza-tools",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "packages/api/src/index.ts",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lanza": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/lanza.ps1",
    "run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/lanza.ps1",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "tsc --noEmit -p packages/api",
    "typecheck:db": "tsc --noEmit -p packages/db",
    "db:check": "npm run check -w @lanza/db",
    "db:migrate": "npm run migrate -w @lanza/db",
    "api:dev": "npm run dev -w @lanza/api",
    "api:start": "npm run start -w @lanza/api",
    "start": "tsx packages/api/src/index.ts",
    "sync:main": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-to-main.ps1",
    "sync:install-hooks": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-git-hooks.ps1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "playwright-core": "^1.61.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "@lanza/db": "workspace:*",
    "@aws-sdk/credential-providers": "^3.758.0",
    "@aws-sdk/rds-signer": "^3.758.0",
    "@vercel/functions": "^2.0.0",
    "@vercel/oidc-aws-credentials-provider": "^3.3.0",
    "@xmldom/xmldom": "^0.8.10",
    "pdf-parse": "^1.1.1",
    "pg": "^8.14.1",
    "pizzip": "^3.1.7"
  }
}
