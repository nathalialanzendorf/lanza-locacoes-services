{
  "name": "lanza-tools",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "packages/api/src/index.ts",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lanza": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/lanza.ps1",
    "run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/lanza.ps1",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "tsc --noEmit -p packages/api",
    "typecheck:db": "tsc --noEmit -p packages/db",
    "typecheck:storage": "tsc --noEmit -p packages/storage",
    "verify:vercel": "node scripts/verify-vercel-deploy.mjs",
    "build:vercel": "node scripts/build-vercel-server.mjs",
    "db:check": "npm run check -w @lanza/db",
    "db:migrate": "npm run migrate -w @lanza/db",
    "db:migrate-relational": "tsx scripts/migrate-json-to-relational.ts",
    "db:parity": "tsx scripts/parity-json-sql.ts",
    "db:cutover": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cutover-postgres-relational.ps1",
    "api:dev": "npm run dev -w @lanza/api",
    "api:start": "npm run start -w @lanza/api",
    "create-admin": "tsx scripts/create-postgres-admin-user.ts",
    "start": "tsx packages/api/src/index.ts",
    "sync:main": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-to-main.ps1",
    "sync:install-hooks": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-git-hooks.ps1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "@types/ws": "^8.18.1",
    "playwright-core": "^1.61.1",
    "tsx": "^4.19.2",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.758.0",
    "@aws-sdk/rds-signer": "^3.758.0",
    "@fastify/busboy": "^3.2.0",
    "@lanza/db": "workspace:*",
    "@lanza/storage": "workspace:*",
    "@tesseract.js-data/por": "^1.0.0",
    "@types/node": "^22.10.0",
    "@types/pdf-parse": "^1.1.5",
    "@vercel/blob": "^0.27.0",
    "@vercel/functions": "^2.0.0",
    "@vercel/oidc-aws-credentials-provider": "^3.3.0",
    "@xmldom/xmldom": "^0.8.10",
    "jose": "^5.10.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.14.1",
    "pizzip": "^3.1.7",
    "sharp": "^0.35.3",
    "tesseract.js": "^7.0.0",
    "typescript": "^5.7.2"
  }
}
