{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --include=dev",
  "buildCommand": "node scripts/build-vercel-server.mjs",
  "rewrites": [
    { "source": "/health", "destination": "/api/health" },
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 300,
      "memory": 1024,
      "includeFiles": "server.mjs,node_modules/tesseract.js-core/**,node_modules/tesseract.js/src/worker-script/**,node_modules/@tesseract.js-data/por/4.0.0_best_int/**,packages/db/sql/**,database/**"
    }
  }
}
