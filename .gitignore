# Windows
desktop.ini

# CNH e comprovante de residência (pastas de contrato) — só local
contratos/**/CNH.*
contratos/**/cnh.*
contratos/**/Residencia.*
contratos/**/Residência.*
contratos/**/residencia.*
contratos/**/residência.*

# CRLV / documento do veículo — só local
veiculos/*
!veiculos/.gitkeep

# Boletos/comprovantes de seguro — canónico em Dropbox (seguroComprovantesDir)
despesas/**/Seguro/

# Dependências da CLI TypeScript (raiz)
/node_modules/

# Frontend React (lanza-web)
lanza-web/node_modules/
lanza-web/dist/

# Credenciais locais (Rastreame, etc.)
.env

# Cache local (perfil do Chrome do Playwright + sessão capturada do pedágio)
.cache/

# Relatórios gerados pela CLI — saída por tipo em relatorios/_tmp/<tipo>/ (só local, não comitar)
relatorios/_tmp/
.vercel
.env*
